mobile/expo-env.d.ts

mobile/android/
mobile/ios/

*.log
*.tsbuildinfo
npm-debug.*
yarn-debug.*
yarn-error.*

.env
.env.*
!.env.example
mobile/.env*.local

.DS_Store
